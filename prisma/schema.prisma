// This is the Prisma schema for a registration system

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Registration {
  id                  Int                @id @default(autoincrement())
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  sacramentStatus     SacramentStatus?
  godparentInfo       GodparentInfo?
  baptismInfo         BaptismInfo?
  paymentInfo         PaymentInfo?
  adminScheduleInfo    AdminScheduleInfo?
}

model SacramentStatus {
  id            Int       @id @default(autoincrement())
  status        String    @unique
  registration   Registration[] @relation("SacramentStatus")
}

model GodparentInfo {
  id            Int       @id @default(autoincrement())
  name          String
  contactInfo   String
  registration   Registration @relation("GodparentInfo")
}

model BaptismInfo {
  id            Int       @id @default(autoincrement())
  date          DateTime
  location      String
  registration   Registration @relation("BaptismInfo")
}

model PaymentInfo {
  id            Int       @id @default(autoincrement())
  amount        Float
  date          DateTime
  registration   Registration @relation("PaymentInfo")
}

model AdminScheduleInfo {
  id            Int       @id @default(autoincrement())
  scheduledDate DateTime
  registration   Registration @relation("AdminScheduleInfo")
}
